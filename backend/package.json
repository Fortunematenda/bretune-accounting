{
  "name": "bretune-accounting-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Bretune Accounting Backend API (NestJS JavaScript)",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js,json --exec node -r ts-node/register/transpile-only -r tsconfig-paths/register src/main.js",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint src --ext .js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:resolve-rollback": "prisma migrate resolve --rolled-back 20260309000000_add_customer_documents_and_product_type",
    "prisma:fix-execute": "prisma db execute --file prisma/fix-migration.sql",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "subscriptions:check-expirations": "node scripts/check-subscription-expirations.js",
    "deploy": "prisma generate && prisma migrate deploy && npm run build"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "nodemailer": "^6.9.13",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@nestjs/cli": "^10.0.0",
    "eslint": "^8.57.1",
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
