enum NetworkDeviceType {
  ROUTER
  SWITCH
  ACCESS_POINT
  OLT
  ONT
  RADIO
  SERVER
  OTHER
}

enum NetworkDeviceStatus {
  ONLINE
  OFFLINE
  DEGRADED
  MAINTENANCE
}

enum ClientServiceStatus {
  ACTIVE
  SUSPENDED
  PENDING
  TERMINATED
}

enum NetworkAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model NetworkDevice {
  id              String              @id @default(cuid())
  name            String
  type            NetworkDeviceType
  status          NetworkDeviceStatus @default(OFFLINE)
  ipAddress       String?
  macAddress      String?
  location        String?
  model           String?
  serialNumber    String?
  firmwareVersion String?
  parentDeviceId  String?
  snmpCommunity   String?
  managementUrl   String?
  uptimeSeconds   Int?
  cpuPercent      Decimal?            @db.Decimal(5, 2)
  memoryPercent   Decimal?            @db.Decimal(5, 2)
  lastSeenAt      DateTime?
  notes           String?
  ownerCompanyName String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  parentDevice    NetworkDevice?      @relation("DeviceHierarchy", fields: [parentDeviceId], references: [id], onDelete: SetNull)
  childDevices    NetworkDevice[]     @relation("DeviceHierarchy")
  interfaces      NetworkInterface[]
  clientLinks     ClientNetworkLink[]
  alerts          NetworkAlert[]

  @@index([type])
  @@index([status])
  @@index([ipAddress])
  @@index([parentDeviceId])
  @@index([ownerCompanyName])
  @@map("network_devices")
}

model NetworkInterface {
  id              String   @id @default(cuid())
