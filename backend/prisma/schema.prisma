// ─── AI Automation ───────────────────────────────────────────────

enum AutomationRuleAction {
  CATEGORIZE
  MATCH_INVOICE
  MATCH_BILL
  TAG
  NOTIFY
}

enum AISuggestionType {
  CATEGORIZE_TRANSACTION
  MATCH_INVOICE
  MATCH_BILL
  DUPLICATE_INVOICE
  DUPLICATE_BILL
  DUPLICATE_EXPENSE
  EXPENSE_SUGGESTION
}

enum AISuggestionStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

model AutomationRule {
  id          String               @id @default(cuid())
  name        String
  description String?
  isActive    Boolean              @default(true)
  priority    Int                  @default(0)
  action      AutomationRuleAction
  conditionsJson Json              // { field, operator, value }[]
  actionParamsJson Json?           // { categoryId, ledgerAccountCode, tag, ... }
  timesApplied Int                 @default(0)
  lastAppliedAt DateTime?
  createdByUserId String
  ownerCompanyName String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([isActive, priority])
  @@index([action])
  @@index([ownerCompanyName])
  @@map("automation_rules")
}

model AISuggestion {
  id             String             @id @default(cuid())
  type           AISuggestionType
  status         AISuggestionStatus @default(PENDING)
  confidence     Decimal            @db.Decimal(5, 4)  // 0.0000 – 1.0000
  sourceEntityType String           // bankTransaction, invoice, bill, expense
  sourceEntityId   String
  targetEntityType String?          // invoice, bill, expenseCategory, ledgerAccount
  targetEntityId   String?
  reasoning      String?            // human-readable explanation
  metaJson       Json?              // extra context (amounts, scores, etc.)
  resolvedAt     DateTime?
  resolvedByUserId String?
  ownerCompanyName String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([type, status])
  @@index([sourceEntityType, sourceEntityId])
  @@index([ownerCompanyName])
  @@index([createdAt])
  @@map("ai_suggestions")
}

