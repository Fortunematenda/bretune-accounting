  name            String   // e.g. "ether1", "wlan0", "ge-0/0/1"
  ifIndex         Int?
  speed           String?  // e.g. "1Gbps", "10Gbps"
  macAddress      String?
  ipAddress       String?
  isUp            Boolean  @default(false)
  rxBytes         BigInt   @default(0)
  txBytes         BigInt   @default(0)
  rxErrors        Int      @default(0)
  txErrors        Int      @default(0)
  lastPolledAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  device NetworkDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("network_interfaces")
}

model ServicePlan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  downloadSpeed   String   // e.g. "50Mbps"
  uploadSpeed     String   // e.g. "25Mbps"
  monthlyPrice    Decimal  @db.Decimal(10, 2)
  dataCapGb       Int?     // null = unlimited
  isActive        Boolean  @default(true)
  ownerCompanyName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientLinks     ClientNetworkLink[]

  @@index([isActive])
  @@index([ownerCompanyName])
  @@map("service_plans")
}

model ClientNetworkLink {
  id              String             @id @default(cuid())
  clientId        String
  deviceId        String?
  servicePlanId   String?
  serviceStatus   ClientServiceStatus @default(PENDING)
