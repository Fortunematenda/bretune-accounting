model Task {
  id                String       @id @default(cuid())
  taskSeq           Int          @unique @default(autoincrement())
  title             String
  description       String?
  type              TaskType     @default(GENERAL)
  priority          TaskPriority @default(MEDIUM)
  status            TaskStatus   @default(PENDING)
  dueDate           DateTime?
  reminderEnabled   Boolean      @default(false)
  reminderAt        DateTime?

  isTemplate        Boolean      @default(false)
  generatedFromTaskId String?

  assignedUserId     String?
  assignedEmployeeId String?

  clientId  String?
  address   String?
  invoiceId String?
  billId    String?
  projectId String?

  recurrenceId String?

  createdByUserId String
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  createdByUser User @relation(fields: [createdByUserId], references: [id])
  assignedUser  User? @relation("TaskAssignedToUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedEmployee Employee? @relation("TaskAssignedToEmployee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  generatedFromTask Task? @relation("TaskGeneratedFrom", fields: [generatedFromTaskId], references: [id], onDelete: SetNull)
  generatedTasks    Task[] @relation("TaskGeneratedFrom")

  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  bill    Bill?    @relation(fields: [billId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  recurrence TaskRecurrence? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)

  activities TaskActivity[]
  notifications TaskNotification[]

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([dueDate])
  @@index([isTemplate])
  @@index([generatedFromTaskId])
  @@index([assignedUserId])
  @@index([assignedEmployeeId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([billId])
  @@index([projectId])
  @@index([recurrenceId])
  @@index([createdByUserId])
  @@map("tasks")
}

