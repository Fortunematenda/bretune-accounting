  servicePlan ServicePlan?    @relation(fields: [servicePlanId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([deviceId])
  @@index([servicePlanId])
  @@index([serviceStatus])
  @@index([ownerCompanyName])
  @@map("client_network_links")
}

enum IspCustomerStatus {
