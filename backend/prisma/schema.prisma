  ACTIVE
  INACTIVE
  BLOCKED
}

enum IspCustomerCategory {
  RESIDENTIAL
  BUSINESS
}

enum IspBillingType {
  RECURRING
  PREPAID
}

model IspCustomer {
  id              String              @id @default(cuid())
  pppoeUsername    String              @unique
  firstName       String
  lastName        String
  companyName     String?
  email           String?
  billingEmail    String?
  phone           String?
  street          String?
  city            String?
  zipCode         String?
  province        String?
  country         String?             @default("South Africa")
  geoLat          String?
  geoLng          String?
  status          IspCustomerStatus   @default(ACTIVE)
  category        IspCustomerCategory @default(RESIDENTIAL)
  billingType     IspBillingType      @default(RECURRING)
  partner         String?
  location        String?
  vatId           String?
  paymentNote     String?
  paymentDate     Int?                @default(1)
  debitOrder      Boolean             @default(false)
  wifiSsid        String?
  wifiPassword    String?
  contactPerson   String?
  notes           String?
  ownerCompanyName String?
  dateAdded       DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  invoices      IspInvoice[]
  notifications IspNotificationLog[]

  @@index([pppoeUsername])
  @@index([status])
  @@index([ownerCompanyName])
  @@index([lastName, firstName])
  @@map("isp_customers")
}

// ── ISP BILLING ──────────────────────────────────

enum IspInvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum IspPaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  MOBILE_MONEY
  DEBIT_ORDER
  ONLINE
}

model IspInvoice {
  id              String           @id @default(cuid())
  invoiceNumber   String           @unique
  customerId      String
  issueDate       DateTime         @default(now())
  dueDate         DateTime
  status          IspInvoiceStatus @default(DRAFT)
  subtotal        Decimal          @db.Decimal(10, 2)
  taxRate         Decimal          @default(0.15) @db.Decimal(5, 4)
  taxAmount       Decimal          @default(0.00) @db.Decimal(10, 2)
  totalAmount     Decimal          @db.Decimal(10, 2)
  amountPaid      Decimal          @default(0.00) @db.Decimal(10, 2)
  balanceDue      Decimal          @db.Decimal(10, 2)
  paidDate        DateTime?
  notes           String?
  periodStart     DateTime?
  periodEnd       DateTime?
  autoGenerated   Boolean          @default(false)
  sentAt          DateTime?
  reminderSentAt  DateTime?
  ownerCompanyName String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  customer IspCustomer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    IspInvoiceItem[]
  payments IspPayment[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([issueDate])
  @@index([ownerCompanyName])
  @@map("isp_invoices")
}

model IspInvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  invoice IspInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("isp_invoice_items")
}

model IspPayment {
  id            String           @id @default(cuid())
  paymentNumber String           @unique
  invoiceId     String
  amount        Decimal          @db.Decimal(10, 2)
  method        IspPaymentMethod @default(CASH)
  reference     String?
  notes         String?
  paymentDate   DateTime         @default(now())
  ownerCompanyName String?
  createdAt     DateTime         @default(now())

  invoice IspInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paymentDate])
  @@index([ownerCompanyName])
  @@map("isp_payments")
}

model IspBillingSettings {
  id                  String  @id @default(cuid())
  autoGenerateDay     Int     @default(1)
  paymentTermsDays    Int     @default(15)
  autoSuspendDays     Int     @default(7)
  taxRate             Decimal @default(0.15) @db.Decimal(5, 4)
  invoicePrefix       String  @default("ISP")
  reminderDaysBefore  Int     @default(3)
  enableAutoSuspend   Boolean @default(true)
  enableAutoReminders Boolean @default(true)
  enableEmailNotifications  Boolean @default(true)
  enableSmsNotifications    Boolean @default(false)
  enableWhatsappNotifications Boolean @default(false)
  notifyOnInvoice     Boolean @default(true)
  notifyOnPayment     Boolean @default(true)
  notifyOnOverdue     Boolean @default(true)
  notifyOnSuspension  Boolean @default(true)
  smsApiProvider      String?
  smsApiKey           String?
  smsApiSecret        String?
  smsSenderId         String?
  whatsappApiUrl      String?
  whatsappApiKey      String?
  whatsappFromNumber  String?
  companyName         String?
  companyAddress      String?
  companyPhone        String?
  companyEmail        String?
  bankName            String?
  bankAccountNumber   String?
  bankBranchCode      String?
  ownerCompanyName    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("isp_billing_settings")
}

enum IspNotificationType {
  INVOICE_CREATED
  PAYMENT_RECEIVED
  OVERDUE_REMINDER
  SUSPENSION_WARNING
  SUSPENDED
  REACTIVATED
}

enum IspNotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

model IspNotificationLog {
  id              String                @id @default(cuid())
  customerId      String
  type            IspNotificationType
  channel         IspNotificationChannel
  recipient       String
  subject         String?
  message         String
  status          String                @default("SENT")
  errorMessage    String?
  invoiceId       String?
  ownerCompanyName String?
  createdAt       DateTime              @default(now())

  customer IspCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@index([ownerCompanyName])
  @@map("isp_notification_logs")
}

// ── FREERADIUS TABLES ─────────────────────────────
// These tables follow the FreeRADIUS SQL schema exactly
// so FreeRADIUS can read/write them directly.

model Radcheck {
  id        Int    @id @default(autoincrement())
  username  String @default("")
  attribute String @default("")
  op        String @default(":=")
  value     String @default("")

  @@index([username])
  @@map("radcheck")
}

model Radreply {
  id        Int    @id @default(autoincrement())
  username  String @default("")
  attribute String @default("")
  op        String @default(":=")
  value     String @default("")

  @@index([username])
  @@map("radreply")
}

model Radgroupcheck {
  id        Int    @id @default(autoincrement())
  groupname String @default("")
  attribute String @default("")
  op        String @default(":=")
  value     String @default("")

  @@index([groupname])
  @@map("radgroupcheck")
}

model Radgroupreply {
  id        Int    @id @default(autoincrement())
  groupname String @default("")
  attribute String @default("")
  op        String @default(":=")
  value     String @default("")

  @@index([groupname])
  @@map("radgroupreply")
}

model Radusergroup {
  id        Int    @id @default(autoincrement())
  username  String @default("")
  groupname String @default("")
  priority  Int    @default(1)

  @@index([username])
  @@map("radusergroup")
}

model Radacct {
  radacctid         BigInt   @id @default(autoincrement())
  acctsessionid     String   @default("")
  acctuniqueid      String   @default("") @unique
  username          String   @default("")
  groupname         String   @default("")
  realm             String   @default("")
  nasipaddress      String   @default("")
  nasportid         String?
  nasporttype       String?
  acctstarttime     DateTime?
  acctupdatetime    DateTime?
  acctstoptime      DateTime?
  acctinterval      Int?
  acctsessiontime   Int?
  acctauthentic     String?
  connectinfo_start String?
  connectinfo_stop  String?
  acctinputoctets   BigInt?
  acctoutputoctets  BigInt?
  calledstationid   String   @default("")
  callingstationid  String   @default("")
  acctterminatecause String  @default("")
  servicetype       String?
  framedprotocol    String?
  framedipaddress   String   @default("")
  framedipv6address String   @default("")
  framedipv6prefix  String   @default("")
  framedinterfaceid String   @default("")
  delegatedipv6prefix String @default("")

  @@index([username])
  @@index([acctsessionid])
  @@index([nasipaddress])
  @@index([acctstarttime])
  @@index([acctstoptime])
  @@index([framedipaddress])
  @@map("radacct")
}

model Radpostauth {
  id        Int      @id @default(autoincrement())
  username  String   @default("")
  pass      String   @default("")
  reply     String   @default("")
  authdate  DateTime @default(now())

  @@index([username])
  @@index([authdate])
  @@map("radpostauth")
}

model Nas {
  id          Int    @id @default(autoincrement())
  nasname     String @default("")
  shortname   String?
  type        String @default("mikrotik")
  ports       Int?
  secret      String @default("secret")
  server      String?
  community   String?
  description String?

  @@index([nasname])
  @@map("nas")
}

model NetworkAlert {
  id              String                @id @default(cuid())
  deviceId        String
  severity        NetworkAlertSeverity
  message         String
  isResolved      Boolean               @default(false)
  resolvedAt      DateTime?
  resolvedByUserId String?
  ownerCompanyName String?
  createdAt       DateTime              @default(now())

  device NetworkDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([severity, isResolved])
  @@index([ownerCompanyName])
  @@index([createdAt])
  @@map("network_alerts")
}
